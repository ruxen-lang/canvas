# Pin tests for Window.open over the headless backend.

Tester.describe("Window") do |t: &var Tester|
  t.it("opens with a title and size and owns a canvas") do
    var w = match Window.open(String.from("hello"), 320, 240)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    t.expect(w.title).to_eq(String.from("hello"))
    t.expect(w.width).to_eq(320)
    t.expect(w.height).to_eq(240)
    t.expect(w.canvas.width).to_eq(320)
    t.expect(w.canvas.height).to_eq(240)
  end

  t.it("rejects invalid sizes") do
    var bad = false
    match Window.open(String.from("x"), 0, 240)
      Ok(_)  -> bad = false
      Err(_) -> bad = true
    end
    t.expect(bad).to_eq(true)

    match Window.open(String.from("x"), 320, 16385)
      Ok(_)  -> bad = false
      Err(_) -> bad = true
    end
    t.expect(bad).to_eq(true)
  end

  t.it("the window's canvas draws a full frame") do
    var w = match Window.open(String.from("frame"), 8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    match w.canvas.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match w.canvas.clear(Color.rgb(0u8, 0u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match w.canvas.draw_rect(Rect.new(2.0f32, 2.0f32, 2.0f32, 2.0f32), Color.rgb(255u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_rect failed")
    end
    match w.canvas.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let blue_c: Color = Color.rgb(0u8, 0u8, 255u8)
    let red_c: Color = Color.rgb(255u8, 0u8, 0u8)
    t.expect(w.canvas.read_pixel(0, 0)).to_eq(blue_c.to_argb as Int)
    t.expect(w.canvas.read_pixel(2, 2)).to_eq(red_c.to_argb as Int)
  end

  t.it("teardown is deterministic (open and drop many)") do
    var i = 0
    while i < 50
      let w = match Window.open(String.from("w"), 32, 32)
        Ok(v)  -> v
        Err(_) -> panic!("Window.open failed")
      end
      t.expect(w.width).to_eq(32)
      i += 1
    end
  end
end
