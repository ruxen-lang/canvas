# Pin tests for ruxen_canvas_draw_rect: fill, clipping, blending.

Tester.describe("Canvas.draw_rect") do |t: &var Tester|
  t.it("fills exactly the half-open pixel box") do
    var c = match Canvas.create(8, 6)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_rect(Rect.new(1.0f32, 1.0f32, 2.0f32, 2.0f32), Color.rgb(255u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let red_c: Color = Color.rgb(255u8, 0u8, 0u8)
    let black_c: Color = Color.rgb(0u8, 0u8, 0u8)
    let red = red_c.to_argb as Int
    let black = black_c.to_argb as Int
    t.expect(c.read_pixel(1, 1)).to_eq(red)
    t.expect(c.read_pixel(2, 2)).to_eq(red)
    t.expect(c.read_pixel(3, 1)).to_eq(black)   # right edge exclusive
    t.expect(c.read_pixel(1, 3)).to_eq(black)   # bottom edge exclusive
    t.expect(c.read_pixel(0, 0)).to_eq(black)   # outside untouched
  end

  t.it("clips to the surface bounds") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.draw_rect(Rect.new(-10.0f32, -10.0f32, 100.0f32, 100.0f32), Color.rgb(0u8, 255u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("oversized draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let green_c: Color = Color.rgb(0u8, 255u8, 0u8)
    let green = green_c.to_argb as Int
    t.expect(c.read_pixel(0, 0)).to_eq(green)
    t.expect(c.read_pixel(3, 3)).to_eq(green)
  end

  t.it("an empty rect draws nothing and is not an error") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.draw_rect(Rect.new(1.0f32, 1.0f32, 0.0f32, 3.0f32), Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("empty draw_rect errored")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end
    t.expect(c.read_pixel(1, 1)).to_eq(0)
  end

  t.it("source-over blends translucent fills") do
    var c = match Canvas.create(2, 2)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    # 50% white over opaque black -> ~50% gray, alpha stays opaque
    match c.draw_rect(Rect.new(0.0f32, 0.0f32, 2.0f32, 2.0f32), Color.new(255u8, 255u8, 255u8, 128u8))
      Ok(_)  -> nil
      Err(_) -> panic!("blend draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let px = c.read_pixel(0, 0)
    let a = (px >> 24) & 0xFF
    let r = (px >> 16) & 0xFF
    t.expect(a).to_eq(255)
    t.expect(r >= 127 && r <= 129).to_eq(true)
  end

  t.it("a fully transparent fill leaves the destination") do
    var c = match Canvas.create(2, 2)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_rect(Rect.new(0.0f32, 0.0f32, 2.0f32, 2.0f32), Color.new(0u8, 0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("transparent draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end
    let white_c: Color = Color.rgb(255u8, 255u8, 255u8)
    t.expect(c.read_pixel(0, 0)).to_eq(white_c.to_argb as Int)
  end

  t.it("outside a frame it errors") do
    var c = match Canvas.create(2, 2)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    var failed = false
    match c.draw_rect(Rect.new(0.0f32, 0.0f32, 1.0f32, 1.0f32), Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> failed = false
      Err(_) -> failed = true
    end
    t.expect(failed).to_eq(true)
  end
end
