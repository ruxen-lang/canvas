# Pin tests for bidi (RTL) — Canvas#draw_text_bidi / #measure_text_bidi /
# #bidi_available?.
#
# Mixed-direction text (LTR with embedded RTL — Hebrew/Arabic) is laid out in
# VISUAL order via ICU ubidi: each directional run is shaped with its resolved
# direction and runs are placed left-to-right in visual order. We pin the
# structural contract: a mixed line lays out a positive width, renders ink across
# the line, and the bidi width is consistent with the component scripts present.
# We do NOT fake RTL — when bidi is unavailable the calls Err / return 0.
#
# docs/decisions/text-fallback.md (bidi decision). Scope: single-line visual
# reordering, LTR base; wrapped bidi paragraphs are the filed remainder.

Tester.describe("Canvas.bidi_available?") do |t: &var Tester|
  t.it("is total and safe to query") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let s = c.bidi_available?
    t.expect(s == true || s == false).to_eq(true)
  end
end

Tester.describe("Canvas.draw_text_bidi mixed direction") do |t: &var Tester|
  t.it("a Latin+Hebrew line lays out a positive width and renders ink") do
    var c = match Canvas.create(240, 40)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let on = c.bidi_available?
    let bg = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    let white = Color.rgb(255u8, 255u8, 255u8)
    let arial = "tests/fixtures/LiberationSans.ttf"
    # "abc שלום 123" — Latin, a Hebrew (RTL) word, and digits. ICU resolves the
    # visual order; we shape each run with its direction.
    let s = "abc שלום 123"

    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    let _ = c.clear(Color.rgb(0u8, 0u8, 0u8))
    let res = c.draw_text_bidi(s.clone, 4.0f32, 30.0f32, 22.0f32, arial, white)
    let _2 = c.end_frame

    if on
      let w = match res
        Ok(v)  -> v
        Err(e) -> panic!("draw_text_bidi failed: #{e}")
      end
      t.expect(w > 0).to_eq(true)

      # ink rendered across the line (left third and right third both lit) — the
      # visual runs were laid out, not collapsed.
      var left_lit = false
      var right_lit = false
      var y = 0
      while y < 40
        var x = 0
        while x < 240
          if c.read_pixel(x, y) != bg
            if x < 60
              left_lit = true
            elsif x > 120
              right_lit = true
            end
          end
          x += 1
        end
        y += 1
      end
      t.expect(left_lit).to_eq(true)
      t.expect(right_lit).to_eq(true)
    else
      var failed = false
      match res
        Ok(_)  -> nil
        Err(_) -> failed = true
      end
      t.expect(failed).to_eq(true)
    end
  end

  t.it("measure agrees the mixed line is wider than the Latin prefix alone") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let on = c.bidi_available?
    let arial = "tests/fixtures/LiberationSans.ttf"
    if on
      let mixed = c.measure_text_bidi("abc שלום", 22.0f32, arial.clone)
      let latin = c.measure_text_bidi("abc", 22.0f32, arial.clone)
      t.expect(mixed > 0).to_eq(true)
      t.expect(latin > 0).to_eq(true)
      t.expect(mixed > latin).to_eq(true)
    else
      let z = c.measure_text_bidi("abc שלום", 22.0f32, arial.clone)
      t.expect(z).to_eq(0)
    end
  end
end
