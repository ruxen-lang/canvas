# Capability / smoke pin for the GPU (Ganesh GL) backend (docs/GPU.md).
#
# This host (and CI) has no usable GL surface, so GPU output cannot be
# pixel-verified here — full pixel verification is deferred to a GL-capable
# desktop, the same posture as the Skia-on-Linux-CI note in docs/SKIA.md. What
# IS asserted here is the contract that must hold on EVERY host:
#
#   * gpu_available? / gpu_active? are total and safe (never crash, return a
#     definite Bool) — the capability probe story mirroring skia_available?.
#   * The backend-selection ladder is sound: when the GPU backend cannot run
#     (no Ganesh symbols / no GL context), the canvas falls back cleanly to the
#     raster (or software) path and STILL produces correct readback. A GPU op
#     that can't run must fall back, never produce silently-wrong pixels.
#   * gpu_active? implies gpu_available? (you can't be rendering on a GPU the
#     process can't even reach), and an offscreen canvas is never GPU-active
#     (GPU needs a GL window — offscreen test canvases stay on raster, the
#     deterministic oracle).

Tester.describe("Canvas.gpu_available?") do |t: &var Tester|
  t.it("is total and safe to query") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    # We don't pin the value (it depends on whether libSkiaSharp + its gr_*
    # symbols are present); only that querying it is safe and total.
    let avail = c.gpu_available?
    t.expect(avail == true || avail == false).to_eq(true)
  end

  t.it("an offscreen canvas is never GPU-active") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    # Offscreen canvases have no GL window, so they are never on the GPU rung —
    # they render on the raster/software path, which is the test oracle.
    t.expect(c.gpu_active?).to_eq(false)
  end

  t.it("gpu_active? implies gpu_available?") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    # If the canvas were GPU-active, the GPU backend must be available. The
    # converse need not hold (available but no GL window -> not active). On this
    # offscreen canvas active? is false, so the implication holds vacuously; the
    # point is the relationship never inverts.
    let active = c.gpu_active?
    let avail = c.gpu_available?
    if active
      t.expect(avail).to_eq(true)
    else
      t.expect(active).to_eq(false)
    end
  end
end

Tester.describe("GPU backend falls back cleanly to raster") do |t: &var Tester|
  t.it("clear + draw_rect read back correctly with GPU unavailable") do
    # The non-negotiable invariant: when the GPU path is not taken, drawing is
    # byte-exact on the fallback. This is the exact same contract skia_backend.rx
    # asserts, re-asserted from the GPU-probe side so a future GPU regression
    # that silently corrupted the fallback would fail here too.
    var c = match Canvas.create(8, 6)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    # An offscreen canvas must NOT be GPU-active (no GL window).
    t.expect(c.gpu_active?).to_eq(false)

    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_rect(Rect.new(2.0f32, 1.0f32, 3.0f32, 2.0f32), Color.rgb(0u8, 128u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let fill = Color.rgb(0u8, 128u8, 255u8).to_argb as Int
    let bg = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    t.expect(c.read_pixel(2, 1)).to_eq(fill)
    t.expect(c.read_pixel(4, 2)).to_eq(fill)
    t.expect(c.read_pixel(5, 1)).to_eq(bg)
    t.expect(c.read_pixel(0, 0)).to_eq(bg)
  end
end

Tester.describe("Window.show_gpu — live path") do |t: &var Tester|
  t.it("show_gpu either brings up a GPU window or falls back cleanly") do
    # Adaptive, like window_live.rx: on a GL-capable desktop the GPU branch runs
    # (a GL window appears briefly and gpu_active? is true); on a headless / no
    # GL / no Ganesh host show_gpu falls back to the raster show path, which
    # itself either shows a raster window or fails cleanly. Either way the
    # canvas keeps working and the window is taken down at the end.
    var w = match Window.open(String.from("canvas gpu pin"), 32, 24)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end

    match w.canvas.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match w.canvas.clear(Color.rgb(10u8, 20u8, 30u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match w.canvas.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let shown = match w.show_gpu
      Ok(_)  -> true
      Err(_) -> false
    end

    if shown
      # Some window (GPU or raster) is up; present must succeed on it.
      t.expect(w.windowed).to_eq(true)
      t.expect(Window.shown?).to_eq(true)
      match w.present
        Ok(_)  -> nil
        Err(_) -> panic!("present failed on a shown window")
      end
      # If the GPU surface came up, gpu_active? is true; if we fell back to the
      # raster window, it is false. Both are valid — assert only that the probe
      # is total here (it never crashes mid-live-window).
      let g = w.canvas.gpu_active?
      t.expect(g == true || g == false).to_eq(true)
      w.hide
      t.expect(Window.shown?).to_eq(false)
    else
      # Fully headless: no window, canvas still works, no GPU surface.
      t.expect(w.windowed).to_eq(false)
      t.expect(Window.shown?).to_eq(false)
      t.expect(w.canvas.gpu_active?).to_eq(false)
    end

    # The framebuffer is observable on both branches (opaque draw is backend
    # independent — the raster oracle still holds).
    let bg = Color.rgb(10u8, 20u8, 30u8).to_argb as Int
    t.expect(w.canvas.read_pixel(0, 0)).to_eq(bg)
  end
end

# ---- Metal backend (Apple offscreen GPU; docs/GPU.md) ----
#
# The Metal backend renders to an OFFSCREEN GPU surface with NO window/display
# (MTLCreateSystemDefaultDevice returns the GPU headless) and reads pixels back,
# so it is the first GPU backend that CAN be pixel-verified locally — in a normal
# process. It is verified end-to-end that way (clear + draw_rect read back
# byte-exact 0xFF0080FF; see the commit + docs/GPU.md).
#
# IT IS NOT pixel-verified INSIDE THIS HARNESS, on purpose. Apple forbids using
# Metal in a process that fork()s without exec(); the test harness runs each `it`
# in a forked child, and Metal's runtime shader-compiler XPC service
# (MTLCompilerService) is unreachable post-fork — `clear` works but any draw that
# needs a runtime-compiled shader (draw_rect, etc.) dies in the forked child.
# Verified: the identical clear+draw_rect renders correctly in a non-forked
# process but produces nothing in a forked child. So these pins assert the
# CAPABILITY + CLEAN-FALLBACK contract (safe everywhere), and the real GPU
# render+readback is a standalone-process verification documented in docs/GPU.md
# — NOT a forked draw here (which would hang/blank the child).

Tester.describe("Canvas.gpu_metal_available?") do |t: &var Tester|
  t.it("is total and safe to query, and backend_kind is sane") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    let m = c.gpu_metal_available?
    t.expect(m == true || m == false).to_eq(true)
    # Metal implies the umbrella GPU capability (can't have Metal without a GPU
    # backend being available).
    if m
      t.expect(c.gpu_available?).to_eq(true)
    end
    # An offscreen canvas that was never put into GPU mode is on the raster path:
    # not GPU-active, backend kind = none (0). Never a draw here (fork-unsafe).
    t.expect(c.gpu_active?).to_eq(false)
    t.expect(c.gpu_backend_kind).to_eq(0)
  end
end

Tester.describe("Metal backend falls back cleanly to raster") do |t: &var Tester|
  t.it("readback stays byte-exact on the raster path (Metal not engaged)") do
    # The non-negotiable invariant: when the Metal GPU path is NOT taken, drawing
    # is byte-exact on the raster/software fallback. We deliberately do NOT call
    # enable_gpu_offscreen here (the forked child cannot run Metal draws); this
    # pins that the raster oracle the GPU path reuses for readback is correct.
    var c = match Canvas.create(8, 6)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    t.expect(c.gpu_active?).to_eq(false)
    t.expect(c.gpu_backend_kind).to_eq(0)

    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_rect(Rect.new(2.0f32, 1.0f32, 3.0f32, 2.0f32), Color.rgb(0u8, 128u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_rect failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let fill = Color.rgb(0u8, 128u8, 255u8).to_argb as Int
    let bg = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    t.expect(c.read_pixel(2, 1)).to_eq(fill)
    t.expect(c.read_pixel(4, 2)).to_eq(fill)
    t.expect(c.read_pixel(5, 1)).to_eq(bg)
    t.expect(c.read_pixel(0, 0)).to_eq(bg)
  end
end
