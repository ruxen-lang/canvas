# Pin tests for ICU Unicode SEGMENTATION: Canvas#grapheme_count /
# #grapheme_boundary_at / #icu_available?.
#
# ICU (the system libicucore on macOS — no new dependency) gives grapheme-cluster
# boundaries for L2's caret/selection. The decisive pin is the Unicode-correct one:
# an emoji+ZWJ sequence (a family emoji) is ONE grapheme, not the count of its
# component codepoints. Boundaries are returned as UTF-8 byte offsets (what L2
# indexes a String by). When ICU is unavailable the calls return 0 / -1 cleanly.
#
# docs/decisions/text-fallback.md.

Tester.describe("Canvas.icu_available?") do |t: &var Tester|
  t.it("is total and safe to query") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let s = c.icu_available?
    t.expect(s == true || s == false).to_eq(true)
  end
end

Tester.describe("Canvas.grapheme_count") do |t: &var Tester|
  t.it("counts plain ASCII one-per-char") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    if c.icu_available?
      t.expect(c.grapheme_count("hello")).to_eq(5)
    else
      t.expect(c.grapheme_count("hello")).to_eq(0)
    end
  end

  t.it("an emoji+ZWJ family sequence is ONE grapheme") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    # "a👨‍👩‍👧b" — a, the ZWJ family emoji (one grapheme), b => 3 graphemes.
    # The family emoji is 4 codepoints joined by ZWJ; a naive codepoint count
    # would give many more. Only Unicode grapheme segmentation gives 3.
    let s = "a👨‍👩‍👧b"
    if c.icu_available?
      t.expect(c.grapheme_count(s)).to_eq(3)
    else
      t.expect(c.grapheme_count(s)).to_eq(0)
    end
  end

  t.it("CJK counts one grapheme per Han character") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    if c.icu_available?
      t.expect(c.grapheme_count("中文")).to_eq(2)
    else
      t.expect(c.grapheme_count("中文")).to_eq(0)
    end
  end
end

Tester.describe("Canvas.draw_paragraph_icu CJK wrap") do |t: &var Tester|
  t.it("a CJK paragraph wraps at character boundaries (not one overflowing line)") do
    var c = match Canvas.create(120, 200)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let on = c.icu_available? && c.fallback_available?
    let white = Color.rgb(255u8, 255u8, 255u8)
    # 8 Han characters; CJK has no spaces, so greedy-whitespace wrap would put them
    # all on ONE overflowing line. ICU line-break wraps between characters, so in a
    # narrow column this lays out across MULTIPLE lines (height > one line).
    let cjk = "中文换行测试文字"

    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    let _ = c.clear(Color.rgb(0u8, 0u8, 0u8))
    let res = c.draw_paragraph_icu(cjk.clone, 2.0f32, 24.0f32, 60.0f32, 18.0f32, 0, white)
    let _2 = c.end_frame

    if on
      let total_h = match res
        Ok(v)  -> v
        Err(e) -> panic!("draw_paragraph_icu failed: #{e}")
      end
      # one line of 18px text is < 40px; 8 Han chars in a 60px column must wrap to
      # at least 2 lines, so the block height exceeds a single line height.
      let one_line = c.text_height
      t.expect(total_h > one_line).to_eq(true)
      # the measured width of the wrapped block fits the column (content width
      # <= max_width, proving it wrapped rather than overflowing).
      let w = c.measure_paragraph_icu_width(cjk.clone, 60.0f32, 18.0f32)
      t.expect(w > 0).to_eq(true)
      t.expect(w <= 60).to_eq(true)
    else
      var failed = false
      match res
        Ok(_)  -> nil
        Err(_) -> failed = true
      end
      t.expect(failed).to_eq(true)
    end
  end
end

Tester.describe("Canvas.grapheme_boundary_at") do |t: &var Tester|
  t.it("maps grapheme indices to UTF-8 byte offsets") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    if c.icu_available?
      # "a中b": byte layout is a(1) 中(3 bytes) b(1) => boundaries 0,1,4,5.
      let s = "a中b"
      t.expect(c.grapheme_boundary_at(s.clone, 0)).to_eq(0)
      t.expect(c.grapheme_boundary_at(s.clone, 1)).to_eq(1)
      t.expect(c.grapheme_boundary_at(s.clone, 2)).to_eq(4)   # past the 3-byte 中
      t.expect(c.grapheme_boundary_at(s.clone, 3)).to_eq(5)   # end (byte length)
      t.expect(c.grapheme_boundary_at(s, 4)).to_eq(-1)        # out of range
    else
      t.expect(c.grapheme_boundary_at("a中b", 1)).to_eq(-1)
    end
  end
end
