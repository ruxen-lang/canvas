# Pin tests for the text-entry fix: printable chars go through SDL_TEXTINPUT
# (Event.TextInput, codepoint), control keys via Event.KeyDown (allowlist +
# auto-repeat filtered). The bug was forwarding raw SDL_KEYDOWN keysyms as if
# they were characters (no shift/layout, repeats, stray printables).
#
# The live SDL pump is gated off in the harness, so these drive the pump's EXACT
# handling via headless seams (window_pump_test_text / _keydown) and assert the
# event the pump would emit.

Tester.describe("text input -> Event.TextInput(codepoint)") do |t: &var Tester|
  t.it("typing 'A' yields TextInput(65)") do
    var w = match Window.open("text", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    let cp = w.canvas.raw.window_pump_test_text(&"A")
    t.expect(cp).to_eq(65)
    var ok = false
    match w.poll_event
      Some(Event.TextInput(c)) -> ok = c == 65
      _ -> ok = false
    end
    t.expect(ok).to_eq(true)
  end

  t.it("typing 'a' yields TextInput(97), not a KeyDown") do
    var w = match Window.open("text2", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    let _ = w.canvas.raw.window_pump_test_text(&"a")
    var got = -1
    match w.poll_event
      Some(Event.TextInput(c)) -> got = c
      Some(Event.KeyDown(_))   -> got = -2   # must NOT be a KeyDown
      _ -> got = -1
    end
    t.expect(got).to_eq(97)
  end

  t.it("a 2-byte UTF-8 char decodes to its codepoint") do
    var w = match Window.open("text3", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    # U+00E9 'é' = 0xC3 0xA9 -> codepoint 233
    let cp = w.canvas.raw.window_pump_test_text(&"é")
    t.expect(cp).to_eq(233)
    var ok = false
    match w.poll_event
      Some(Event.TextInput(c)) -> ok = c == 233
      _ -> ok = false
    end
    t.expect(ok).to_eq(true)
  end
end

Tester.describe("keydown: control-only + auto-repeat filtered") do |t: &var Tester|
  t.it("a printable keysym ('a' = 97) is DROPPED (TextInput owns it)") do
    var w = match Window.open("kd1", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    let emitted = w.canvas.raw.window_pump_test_keydown(97, 0, 0)
    t.expect(emitted).to_eq(0)             # filtered: no event
    var none = true
    match w.poll_event
      nil -> none = true
      _   -> none = false
    end
    t.expect(none).to_eq(true)
  end

  t.it("backspace (keysym 8) -> KeyDown(8)") do
    var w = match Window.open("kd2", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    let emitted = w.canvas.raw.window_pump_test_keydown(8, 0, 0)
    t.expect(emitted).to_eq(1)
    var ok = false
    match w.poll_event
      Some(Event.KeyDown(k)) -> ok = k == 8
      _ -> ok = false
    end
    t.expect(ok).to_eq(true)
  end

  t.it("Left arrow (1073741904) -> KeyDown") do
    var w = match Window.open("kd3", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    let emitted = w.canvas.raw.window_pump_test_keydown(1073741904, 0, 0)
    t.expect(emitted).to_eq(1)
    var ok = false
    match w.poll_event
      Some(Event.KeyDown(k)) -> ok = k == 1073741904
      _ -> ok = false
    end
    t.expect(ok).to_eq(true)
  end

  t.it("Enter (13) -> KeyDown, but its auto-REPEAT is filtered") do
    var w = match Window.open("kd4", 64, 48)
      Ok(v)  -> v
      Err(_) -> panic!("Window.open failed")
    end
    # first press (repeat=0) emits
    let first = w.canvas.raw.window_pump_test_keydown(13, 0, 0)
    t.expect(first).to_eq(1)
    # held repeat (repeat=1) is filtered -> no event
    let rep = w.canvas.raw.window_pump_test_keydown(13, 1, 0)
    t.expect(rep).to_eq(0)
  end
end
