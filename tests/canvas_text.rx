# Pin tests for ruxen_canvas_draw_text / _measure_text (5x7 bitmap font).

Tester.describe("Canvas.draw_text") do |t: &var Tester|
  t.it("draws glyph pixels above the baseline") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    # 'A' at baseline y=7 occupies rows 0..6: apex (2,0), legs at x=0 and
    # x=4, crossbar row 4 (cols 1..3 carry 0x11 = rows 0 and 4)
    match c.draw_text(String.from("A"), 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let white_c: Color = Color.rgb(255u8, 255u8, 255u8)
    let black_c: Color = Color.rgb(0u8, 0u8, 0u8)
    let white = white_c.to_argb as Int
    let black = black_c.to_argb as Int
    t.expect(c.read_pixel(2, 0)).to_eq(white)   # apex
    t.expect(c.read_pixel(0, 3)).to_eq(white)   # left leg
    t.expect(c.read_pixel(4, 3)).to_eq(white)   # right leg
    t.expect(c.read_pixel(2, 4)).to_eq(white)   # crossbar
    t.expect(c.read_pixel(0, 0)).to_eq(black)   # top-left corner stays empty
    t.expect(c.read_pixel(0, 7)).to_eq(black)   # baseline row stays empty
  end

  t.it("a space draws nothing") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.draw_text(String.from(" "), 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    var lit = 0
    var y = 0
    while y < 8
      var x = 0
      while x < 8
        if c.read_pixel(x, y) != 0
          lit += 1
        end
        x += 1
      end
      y += 1
    end
    t.expect(lit).to_eq(0)
  end

  t.it("advances 6px per character") do
    var c = match Canvas.create(16, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    # '!' is a single column at x=2 of the glyph cell (0x5F: rows 0..4, 6)
    match c.draw_text(String.from("!!"), 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let white_c: Color = Color.rgb(255u8, 255u8, 255u8)
    let white = white_c.to_argb as Int
    t.expect(c.read_pixel(2, 2)).to_eq(white)   # first '!'
    t.expect(c.read_pixel(8, 2)).to_eq(white)   # second '!' at x=6+2
  end

  t.it("clips text that runs off the surface") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.draw_text(String.from("WWWW"), 0.0f32, 20.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("below-surface draw_text failed")
    end
    match c.draw_text(String.from("WWWW"), 0.0f32, -20.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("above-surface draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end
    # nothing crashed; offscreen baselines leave the surface untouched
    t.expect(c.read_pixel(0, 0)).to_eq(0)
  end

  t.it("outside a frame it errors") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    var failed = false
    match c.draw_text(String.from("A"), 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> failed = false
      Err(_) -> failed = true
    end
    t.expect(failed).to_eq(true)
  end
end

Tester.describe("Canvas.measure_text") do |t: &var Tester|
  t.it("measures the single-line advance width") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    let empty = String.from("")
    let one = String.from("A")
    let two = String.from("AB")
    t.expect(c.measure_text(&empty)).to_eq(0)
    t.expect(c.measure_text(&one)).to_eq(5)
    t.expect(c.measure_text(&two)).to_eq(11)
  end
end
