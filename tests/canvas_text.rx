# Pin tests for text: draw_text / measure_text / text_height.
#
# Backend-agnostic invariants — exact glyph pixels and advances differ between
# the real Skia font and the 5x7 bitmap fallback, so these assert STRUCTURAL
# properties (ink appears in-bounds, empties draw nothing, measure is positive
# and monotonic, height is positive) that hold under either backend.

Tester.describe("Canvas.draw_text") do |t: &var Tester|
  t.it("draws ink for a glyph, leaving the origin corner clear") do
    var c = match Canvas.create(24, 20)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_text("A", 2.0f32, 14.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let black = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    var lit = 0
    var y = 0
    while y < 20
      var x = 0
      while x < 24
        if c.read_pixel(x, y) != black
          lit += 1
        end
        x += 1
      end
      y += 1
    end
    t.expect(lit > 0).to_eq(true)               # the glyph drew something
    t.expect(c.read_pixel(0, 0)).to_eq(black)   # left of / above the origin: clear
    t.expect(c.read_pixel(23, 0)).to_eq(black)  # far corner: clear
  end

  t.it("a space draws nothing") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_text(" ", 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end

    let black = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    var lit = 0
    var y = 0
    while y < 8
      var x = 0
      while x < 8
        if c.read_pixel(x, y) != black
          lit += 1
        end
        x += 1
      end
      y += 1
    end
    t.expect(lit).to_eq(0)
  end

  t.it("offscreen baselines leave the surface untouched") do
    var c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_text("WWWW", 0.0f32, 40.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("below-surface draw_text failed")
    end
    match c.draw_text("WWWW", 0.0f32, -40.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("above-surface draw_text failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end
    let black = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    t.expect(c.read_pixel(0, 0)).to_eq(black)
  end

  t.it("outside a frame it errors") do
    var c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    var failed = false
    match c.draw_text("A", 0.0f32, 7.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> failed = false
      Err(_) -> failed = true
    end
    t.expect(failed).to_eq(true)
  end
end

Tester.describe("Canvas.measure_text") do |t: &var Tester|
  t.it("is zero for empty, positive and monotonic otherwise") do
    let c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    t.expect(c.measure_text("")).to_eq(0)
    let one = c.measure_text("A")
    let many = c.measure_text("AAAA")
    t.expect(one > 0).to_eq(true)
    t.expect(many >= one).to_eq(true)
  end
end

Tester.describe("Canvas.text_height") do |t: &var Tester|
  t.it("reports a positive font line height") do
    let c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    t.expect(c.text_height > 0).to_eq(true)
  end

  t.it("line_height is an alias for text_height (both names, one body)") do
    let c = match Canvas.create(4, 4)
      Ok(v)  -> v
      Err(_) -> panic!("Canvas.create failed")
    end
    t.expect(c.line_height).to_eq(c.text_height)
    t.expect(c.line_height > 0).to_eq(true)
  end
end

Tester.describe("Canvas font sizing") do |t: &var Tester|
  t.it("a larger size is taller and wider when Skia is active") do
    let c = match Canvas.create(8, 8)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    let small_h = c.text_height_sized(10.0f32)
    let large_h = c.text_height_sized(30.0f32)
    let small_w = c.measure_text_sized("AAA", 10.0f32)
    let large_w = c.measure_text_sized("AAA", 30.0f32)
    if c.skia_active?
      t.expect(large_h > small_h).to_eq(true)
      t.expect(large_w > small_w).to_eq(true)
    else
      t.expect(large_h).to_eq(small_h)   # bitmap fallback ignores size
    end
  end

  t.it("draw_text_sized renders ink") do
    var c = match Canvas.create(48, 40)
      Ok(v)  -> v
      Err(_) -> panic!("create failed")
    end
    match c.begin_frame
      Ok(_)  -> nil
      Err(_) -> panic!("begin_frame failed")
    end
    match c.clear(Color.rgb(0u8, 0u8, 0u8))
      Ok(_)  -> nil
      Err(_) -> panic!("clear failed")
    end
    match c.draw_text_sized("Hi", 4.0f32, 30.0f32, 24.0f32, Color.rgb(255u8, 255u8, 255u8))
      Ok(_)  -> nil
      Err(_) -> panic!("draw_text_sized failed")
    end
    match c.end_frame
      Ok(_)  -> nil
      Err(_) -> panic!("end_frame failed")
    end
    let black = Color.rgb(0u8, 0u8, 0u8).to_argb as Int
    var lit = 0
    var y = 0
    while y < 40
      var x = 0
      while x < 48
        if c.read_pixel(x, y) != black
          lit += 1
        end
        x += 1
      end
      y += 1
    end
    t.expect(lit > 0).to_eq(true)
  end
end
